# ============================================================================
# TDSQL数据库SQL审核工具 v1.0.2 生产配置模板
# 使用: 复制为 deploy/.env 并按环境填写；install.sh 会安装到 <安装目录>/.env
# 安全: .env 含口令与密钥，权限保持 600，随备份策略一起离线备份
# ============================================================================

# ── 系统元数据库（TDSQL 集中式实例，MySQL 协议）【必填】 ─────────────────
# 建库与授权 SQL 见《部署手册-v1.0.2》3.2 节
SQLCHECK_DB_HOST=
SQLCHECK_DB_PORT=3306
SQLCHECK_DB_USER=sqlcheck_app
SQLCHECK_DB_PASSWORD=
SQLCHECK_DB_NAME=tdsql_sqlcheck
# 元数据库连接池大小（每 worker），几百实例/数十并发用户建议 10-20
SQLCHECK_DB_POOL_SIZE=10

# ── 认证与安全【生产必须按此设置】 ───────────────────────────────────────
AUTH_ENABLED=true
# HMAC 令牌签名密钥：留空则 install.sh 首次部署自动生成并追加固化。
# 重要：必须持久且各节点一致；更换会使全部已登录令牌失效。
AUTH_SECRET_KEY=
# admin 初始口令（首次启动创建 admin 用户用；首登强制改密）【必填】
ADMIN_INITIAL_PASSWORD=
AUTH_TOKEN_TTL_HOURS=8
AUTH_MAX_LOGIN_FAILURES=5
AUTH_LOCK_MINUTES=15
# SQL文本入库脱敏（字面量→?，防客户敏感数据落地）
DATA_MASKING_ENABLED=true
# OpenAPI 文档端点(/docs)是否公开；生产建议 false
DOCS_PUBLIC=false
# 同源部署留空即可；如前端独立域名再填（逗号分隔）
CORS_ALLOW_ORIGINS=

# ── GitLab 集成（不用可全部留默认） ──────────────────────────────────────
GITLAB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_ALLOW_INSECURE=false

# ── 调度与保留 ──────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_CRON_HOUR=2
SCHEDULER_CRON_MINUTE=0
SCHEDULER_SLOW_QUERY_LIMIT=100
SCHEDULER_SLOW_QUERY_MIN_TIME=1.0
RETENTION_CRON_HOUR=3

# ── 容量与限流（按规模调整） ─────────────────────────────────────────────
# 目标实例连接池上限（纳管几百实例时的活跃池上限）
CONNECTION_POOL_MAX_INSTANCES=200
CONNECTION_POOL_IDLE_SECONDS=600
# 扫描并发限流（保护目标库）
MAX_CONCURRENT_SCANS_PER_CONNECTION=1
MAX_CONCURRENT_SCANS_GLOBAL=8

# ── 可观测性 ────────────────────────────────────────────────────────────
METRICS_ENABLED=true

# ── 报告输出目录（相对安装目录或绝对路径） ────────────────────────────────
REPORT_OUTPUT_DIR=/opt/tdsql-sqlcheck/reports

# ── V1 兼容: 默认目标 TDSQL 实例（可全部留空，实例统一在界面"实例管理"配置）──
TDSQL_HOST=
TDSQL_PORT=15002
TDSQL_USER=
TDSQL_PASSWORD=
TDSQL_DATABASE=
TDSQL_CHARSET=utf8mb4
TDSQL_CONNECT_TIMEOUT=10
TDSQL_READ_TIMEOUT=30
